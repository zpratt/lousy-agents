{
    "name": "lousy-agents",
    "version": "1.0.2",
    "private": true,
    "description": "Workspace monorepo for Lousy Agents scaffolding, MCP integrations, and npm script telemetry",
    "type": "module",
    "workspaces": [
        "packages/core",
        "packages/lint",
        "packages/cli",
        "packages/mcp",
        "packages/action",
        "packages/agent-shell"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zpratt/lousy-agents.git"
    },
    "author": "zpratt",
    "license": "BSD-2-Clause-Patent",
    "bugs": {
        "url": "https://github.com/zpratt/lousy-agents/issues"
    },
    "homepage": "https://github.com/zpratt/lousy-agents#readme",
    "keywords": [
        "ai",
        "cli",
        "copilot",
        "mcp",
        "monorepo",
        "scaffolding"
    ],
    "scripts": {
        "dev": "tsx packages/cli/src/index.ts",
        "build": "npm run build --workspace=packages/lint --workspace=packages/cli --workspace=packages/mcp --workspace=packages/agent-shell --workspace=packages/action",
        "start": "node packages/cli/dist/index.js",
        "test": "vitest run",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "lint:architecture": "depcruise --config .dependency-cruiser.cjs packages/lint/src packages/core/src",
        "lint:workflows": "actionlint",
        "lint:yaml": "yamllint ."
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@modelcontextprotocol/server-sequential-thinking": "2025.12.18",
        "@rspack/cli": "2.0.3",
        "@rspack/core": "2.0.3",
        "@types/chance": "1.1.8",
        "@types/mdast": "4.0.4",
        "@types/node": "25.9.1",
        "@upstash/context7-mcp": "2.2.5",
        "chance": "1.1.13",
        "dependency-cruiser": "17.4.0",
        "fast-check": "4.8.0",
        "testcontainers": "11.14.0",
        "tsx": "4.22.3",
        "typescript": "6.0.3",
        "vitest": "4.1.6",
        "whatwg-fetch": "3.6.20"
    }
}

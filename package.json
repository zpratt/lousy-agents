{
    "name": "lousy-agents",
    "version": "1.0.2",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/core",
        "packages/cli",
        "packages/mcp",
        "packages/action"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zpratt/lousy-agents.git"
    },
    "author": "zpratt",
    "license": "MIT",
    "scripts": {
        "dev": "tsx packages/cli/src/index.ts",
        "build": "npm run build --workspace=packages/cli --workspace=packages/mcp",
        "start": "node packages/cli/dist/index.js",
        "test": "vitest run",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "lint:workflows": "actionlint",
        "lint:yaml": "yamllint ."
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.6",
        "@rspack/cli": "1.7.8",
        "@rspack/core": "1.7.8",
        "@types/chance": "1.1.7",
        "@types/mdast": "4.0.4",
        "@types/node": "25.4.0",
        "chance": "1.1.13",
        "testcontainers": "11.12.0",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "vitest": "4.0.18",
        "whatwg-fetch": "3.6.20"
    }
}

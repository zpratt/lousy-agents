{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "types": ["node"],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}

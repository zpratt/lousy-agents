        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "lint:workflows": "actionlint",
        "lint:yaml": "yamllint .",
        "db:migrate": "tsx src/db/migrate.ts"
    },
    "dependencies": {
        "@fastify/cors": "11.0.1",
        "@fastify/sensible": "6.0.4",
        "fastify": "5.8.2",
        "kysely": "0.28.12",
        "pino": "9.14.0",
        "postgres": "3.4.8",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.2",
        "@testcontainers/postgresql": "11.12.0",
        "@types/node": "24.12.0",
        "chance": "1.1.13",
        "testcontainers": "11.12.0",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "vitest": "4.1.0"
    }

{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "helpers:pinGitHubActionDigestsToSemver",
        "security:openssf-scorecard"
    ],
    "automerge": true,
    "platformAutomerge": true,
    "lockFileMaintenance": {
        "enabled": true,
        "automergeType": "branch"
    },
    "semanticCommitType": "fix",
    "semanticCommitScope": "deps",
    "pinDigests": true,
    "packageRules": [
        {
            "description": "Pin all npm dependencies to exact versions",
            "matchManagers": ["npm"],
            "rangeStrategy": "pin"
        }
    ],
    "customManagers": [
        {
            "description": "Track jq version in mise.toml (needs extractVersionTemplate because tags use jq-x.y.z format)",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)mise\\.toml$/"],
            "matchStrings": ["(?:^|\\n)jq\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
            "depNameTemplate": "jqlang/jq",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^jq-(?<version>.*)$"
        },
        {
            "description": "Track vhs version in mise.toml",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)mise\\.toml$/"],
            "matchStrings": [
                "(?:^|\\n)vhs\\s*=\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "charmbracelet/vhs",
            "datasourceTemplate": "github-releases"
        },
        {
            "description": "Track mise minimum version requirement",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)mise\\.toml$/"],
            "matchStrings": ["min_version\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
            "depNameTemplate": "jdx/mise",
            "datasourceTemplate": "github-releases"
        },
        {
            "description": "Track Node.js version in devcontainer node feature",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)devcontainer\\.json$/"],
            "matchStrings": [
                "\"ghcr\\.io/devcontainers/features/node:[^\"]+\":\\s*\\{[^{}]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "nodejs/node",
            "datasourceTemplate": "github-tags",
            "versioningTemplate": "node"
        },
        {
            "description": "Track GitHub CLI version in devcontainer github-cli feature",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)devcontainer\\.json$/"],
            "matchStrings": [
                "\"ghcr\\.io/devcontainers/features/github-cli:[^\"]+\":\\s*\\{[^{}]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "cli/cli",
            "datasourceTemplate": "github-releases"
        },
        {
            "description": "Track Claude Code version in devcontainer claude-code feature",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)devcontainer\\.json$/"],
            "matchStrings": [
                "\"ghcr\\.io/anthropics/devcontainer-features/claude-code:[^\"]+\":\\s*\\{[^{}]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "anthropics/claude-code",
            "datasourceTemplate": "github-releases"
        },
        {
            "description": "Track reviewdog CLI version in action.yml",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)action\\.ya?ml$/"],
            "matchStrings": ["reviewdog_version:\\s*'(?<currentValue>[^']+)'"],
            "depNameTemplate": "reviewdog/reviewdog",
            "datasourceTemplate": "github-releases"
        },
        {
            "description": "Track actionlint version in devcontainer actionlint feature",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)devcontainer\\.json$/"],
            "matchStrings": [
                "\"ghcr\\.io/devcontainers-extra/features/actionlint:[^\"]+\":\\s*\\{[^{}]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "rhysd/actionlint",
            "datasourceTemplate": "github-releases"
        },
        {
            "description": "Track Docker-in-Docker feature version (feature manages its own Docker version)",
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)devcontainer\\.json$/"],
            "matchStrings": [
                "\"ghcr\\.io/devcontainers/features/docker-in-docker:(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "devcontainers/features",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^docker-in-docker_v(?<version>.*)$"
        }
    ]
}
